APP_NAME="E-Perpus Standalone"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# DATABASE UTAMA (E-Perpus)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eperpus
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# DATABASE ABSENSI (Sumber sinkronisasi data siswa & guru)
# Hubungkan ke database Sistem Absensi yang sudah ada
# ============================================================
ABSEN_DB_HOST=127.0.0.1
ABSEN_DB_PORT=3306
ABSEN_DB_DATABASE=absen_sell
ABSEN_DB_USERNAME=root
ABSEN_DB_PASSWORD=

# ============================================================
# KONFIGURASI PERPUSTAKAAN
# ============================================================
# Denda keterlambatan per hari (dalam Rupiah)
FINE_PER_DAY=1000

# ============================================================
# SESSION & CACHE
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

VITE_APP_NAME="${APP_NAME}"
